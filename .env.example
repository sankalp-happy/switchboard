# Groq API Key (optional — prefer adding keys via Admin UI)
# If set, will be auto-seeded into the database on first startup
GROQ_API_KEY=

# Google API Key (for Gemini embeddings in semantic cache)
GOOGLE_API_KEY=

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Gateway Config
PORT=8000
HOST=0.0.0.0

# SQLite database path (relative to project root)
SQLITE_DB_PATH=data/switchboard.db

# Fernet encryption key for API keys at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
